# PostDeployConfig.s.sol - Environment Variables
# Copy this file to .env and fill in the actual values before running the script.
#
# Usage:
#   source .env
#   forge script script/PostDeployConfig.s.sol --rpc-url $RPC_URL --broadcast

# ──────────────────────────────────────────────────────────────────────────────
# Required: Deployed proxy addresses (from DeployNavProxy.s.sol output)
# ──────────────────────────────────────────────────────────────────────────────

ORACLE_PROXY=0x0000000000000000000000000000000000000001
NAV4626_PROXY=0x0000000000000000000000000000000000000002
VAULT_PROXY=0x0000000000000000000000000000000000000003

# ──────────────────────────────────────────────────────────────────────────────
# Required: Role assignee addresses
# ──────────────────────────────────────────────────────────────────────────────

# NavOracle: Authorized to call updateRate() to submit new APR values.
NAV_UPDATER=0x0000000000000000000000000000000000000011

# Nav4626 MANAGER_ROLE: Manages user whitelist via setWhitelist(address, bool).
MANAGER=0x0000000000000000000000000000000000000012

# Nav4626 BLOCKLIST_ADMIN_ROLE: Freeze/unfreeze addresses via setFrozen(address, bool).
BLOCKLIST_ADMIN=0x0000000000000000000000000000000000000013

# Nav4626 REDEMPTION_APPROVER_ROLE: Approve/reject redemption requests.
REDEMPTION_APPROVER=0x0000000000000000000000000000000000000014

# Vault SETTLEMENT_OPERATOR_ROLE: Withdraw XAUT from Vault to whitelisted addresses.
SETTLEMENT_OPERATOR=0x0000000000000000000000000000000000000015

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Additional roles (set to 0x0 or leave unset to skip)
# ──────────────────────────────────────────────────────────────────────────────

# Nav4626 EMERGENCY_GUARDIAN_ROLE: Can trigger emergency pause().
# Leave unset or set to 0x0000...0000 to disable emergency pause capability.
# EMERGENCY_GUARDIAN=0x0000000000000000000000000000000000000016

# UPGRADER_ROLE: Authorized to perform UUPS upgrades on all 3 contracts.
# Leave unset or set to 0x0000...0000 to skip upgrader configuration.
# UPGRADER=0x0000000000000000000000000000000000000017

# ──────────────────────────────────────────────────────────────────────────────
# Optional: Vault settlement target whitelist
# ──────────────────────────────────────────────────────────────────────────────

# Comma-separated list of addresses that the settlement operator can withdraw to.
# These are typically project custody addresses (e.g., Ceffu, Cobo custody).
# Leave unset or empty to skip.
# SETTLEMENT_TARGETS=0xAaaa...1111,0xBbbb...2222
